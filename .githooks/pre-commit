#!/bin/sh
# Auto-inject current commit SHA and timestamp into Lua files before commit,
# so log first line shows the exact build.

set -eu

SHA=$(git rev-parse --short HEAD 2>/dev/null || echo "uncommitted")
DATE=$(date +"%Y-%m-%d %H:%M")

update_file() {
    f="$1"
    [ -f "$f" ] || return 0
    sed -i.bak \
        -e "s|^local SCRIPT_VERSION = \".*\"\( *\)-- AUTO-UPDATED BY HOOK|local SCRIPT_VERSION = \"${SHA}\"\1-- AUTO-UPDATED BY HOOK|" \
        -e "s|^local SCRIPT_BUILD   = \".*\"\( *\)-- AUTO-UPDATED BY HOOK|local SCRIPT_BUILD   = \"${DATE}\"\1-- AUTO-UPDATED BY HOOK|" \
        -e "s|^local LIB_VERSION = \".*\"\( *\)-- AUTO-UPDATED BY HOOK|local LIB_VERSION = \"${SHA}\"\1-- AUTO-UPDATED BY HOOK|" \
        -e "s|^local LIB_BUILD   = \".*\"\( *\)-- AUTO-UPDATED BY HOOK|local LIB_BUILD   = \"${DATE}\"\1-- AUTO-UPDATED BY HOOK|" \
        "$f"
    rm -f "${f}.bak"
    git add "$f"
}

update_file "purple_tongue_farm.lua"
update_file "lib/ptf_lib.lua"
